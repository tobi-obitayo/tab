{
  "manifest_version": 3,
  "name": "Tab Dashboard",
  "version": "0.1.1",
  "description": "A personal dashboard for your new tab",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
